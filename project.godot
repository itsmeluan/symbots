; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Symbots"
config/description="Creature-collection RPG — modular robot building, turn-based combat. Mac launch, iOS primary long-term target."
run/main_scene="res://src/scenes/v1/v1_game.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]

EventBus="*res://src/autoloads/event_bus.gd"
Log="*res://src/autoloads/log_autoload.gd"
PartDB="*res://src/autoloads/part_db_autoload.gd"
EnemyDB="*res://src/autoloads/enemy_db_autoload.gd"
MoveDB="*res://src/autoloads/move_db_autoload.gd"
PassiveDB="*res://src/autoloads/passive_db_autoload.gd"
ConsumableDB="*res://src/autoloads/consumable_db_autoload.gd"
WorldLootDB="*res://src/autoloads/world_loot_db_autoload.gd"
RngService="*res://src/autoloads/rng_service_autoload.gd"
SaveLoad="*res://src/autoloads/save_load_autoload.gd"
TBC="*res://src/autoloads/battle_controller_autoload.gd"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"

[display]

window/size/viewport_width=360
window/size/viewport_height=640
window/size/window_width_override=720
window/size/window_height_override=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_ai/plugin.cfg", "res://addons/gut/plugin.cfg")

[importer_defaults]

texture={
"compress/mode": 0,
"detect_3d/compress_to": 0,
"mipmaps/generate": false
}

[rendering]

; Pixel snapping: without these, a sprite at a fractional world position renders its
; art pixels at non-integer screen offsets, so some come out 1 screen pixel wide and
; some 2 — which reads as a blurry sprite against crisp tiles. The player moves by
; MOVE_SPEED * delta, so its position is fractional on almost every frame.
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
