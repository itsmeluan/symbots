; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Symbots"
config/description="Creature-collection RPG — modular robot building, turn-based combat. Mac launch, iOS primary long-term target."
run/main_scene="res://src/scenes/game.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]

EventBus="*res://src/autoloads/event_bus.gd"
Log="*res://src/autoloads/log_autoload.gd"
PartDB="*res://src/autoloads/part_db_autoload.gd"
EnemyDB="*res://src/autoloads/enemy_db_autoload.gd"
MoveDB="*res://src/autoloads/move_db_autoload.gd"
PassiveDB="*res://src/autoloads/passive_db_autoload.gd"
ConsumableDB="*res://src/autoloads/consumable_db_autoload.gd"
WorldLootDB="*res://src/autoloads/world_loot_db_autoload.gd"
RngService="*res://src/autoloads/rng_service_autoload.gd"
SaveLoad="*res://src/autoloads/save_load_autoload.gd"
TBC="*res://src/autoloads/battle_controller_autoload.gd"

[display]

; Pixel-art base resolution. See design/art/art-bible.md §8.3.
; PROVISIONAL (2026-07-19): 960x540 — chosen because the shipped art is authored for it
; (64px terrain tiles, 96px character = ~18% of screen height). 2x exact to 1920x1080.
; §8.3's TODO(native-grid) is still open — this pins the display base, not the
; per-asset native grid.
window/size/viewport_width=960
window/size/viewport_height=540
; Base viewport doubles as the initial OS window size unless overridden;
; without these the Mac window opens at a literal 960x540 px.
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
; expand = no letterbox on iOS ~19.5:9; base res becomes a MINIMUM guaranteed
; visible area, wider screens reveal more world. UI must not use hardcoded
; absolute offsets from screen edges.
window/stretch/aspect="expand"
; integer = floors the scale factor; this is what keeps pixels crisp.
window/stretch/scale_mode="integer"
window/handheld/orientation=0

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[importer_defaults]

texture={
"compress/mode": 0,
"detect_3d/compress_to": 0,
"mipmaps/generate": false
}

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
